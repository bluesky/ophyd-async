record(mbbo, "$(P)Mode") {
    field(DESC, "Energy sensitivity of the image")
    field(DTYP, "Raw Soft Channel")
    field(PINI, "YES")
    field(ZRVL, "10")
    field(ZRST, "Low Energy")
    field(ONVL, "100")
    field(ONST, "High Energy")
}

record(calc, "$(P)Value") {
    field(DESC, "Sensor value simulated from X and Y")
    field(INPA,  "$(P)X:Readback CP")
    field(INPB,  "$(P)Y:Readback CP")
    field(INPC,  "$(CHANNEL)")
    field(INPD,  "$(P)Mode.RVAL CP")
    field(CALC, "CEIL(SIN(A)**C+COS(D+B*A)*COS(A)+2)*999")
    field(EGU,  "cts/s")
    field(PREC, "0")
}
